# Copie este arquivo para .env e ajuste os valores para o seu ambiente.
# O .env nunca deve ser commitado — ele já está no .gitignore.

BEEAI_PROJECT_NAME=BeeAI
BEEAI_DEBUG=false
BEEAI_DATABASE_URL=sqlite:////caminho/absoluto/para/data/db/app.sqlite3
BEEAI_UPLOAD_DIR=/caminho/absoluto/para/data/uploads
BEEAI_ARTIFACTS_DIR=/caminho/absoluto/para/artifacts/models
BEEAI_MAX_UPLOAD_SIZE_MB=15
BEEAI_CORS_ORIGINS=["http://localhost:5173"]

# Necessário quando um modelo gated do Hugging Face estiver ativo no Docker.
# Gere um token Read em https://huggingface.co/settings/tokens
HF_TOKEN=hf_seu_token_read_aqui

# Em staging/prod, defina o host do backend para que as URLs de imagem funcionem corretamente.
# Deixe vazio (ou remova) no ambiente de desenvolvimento — o proxy do Vite cuida disso.
# BEEAI_UPLOADS_BASE_URL=http://seu-host:porta
