# Copie este arquivo para .env e ajuste os valores para o seu ambiente.
# O .env nunca deve ser commitado — ele já está no .gitignore.

AUGOCHLOROPSIS_AI_PROJECT_NAME=Augochloropsis Classifier API
AUGOCHLOROPSIS_AI_DEBUG=false
AUGOCHLOROPSIS_AI_DATABASE_URL=sqlite:////caminho/absoluto/para/data/db/app.sqlite3
AUGOCHLOROPSIS_AI_UPLOAD_DIR=/caminho/absoluto/para/data/uploads
AUGOCHLOROPSIS_AI_ARTIFACTS_DIR=/caminho/absoluto/para/artifacts/models
AUGOCHLOROPSIS_AI_MAX_UPLOAD_SIZE_MB=15
AUGOCHLOROPSIS_AI_CORS_ORIGINS=["http://localhost:5173"]

# Necessário quando um modelo gated do Hugging Face estiver ativo no Docker, como DINOv3.
# Gere um token Read em https://huggingface.co/settings/tokens após aceitar os termos do modelo.
HF_TOKEN=hf_seu_token_read_aqui

# Em staging/prod, defina o host do backend para que as URLs de imagem funcionem corretamente.
# Deixe vazio (ou remova) no ambiente de desenvolvimento — o proxy do Vite cuida disso.
# AUGOCHLOROPSIS_AI_UPLOADS_BASE_URL=http://seu-host:porta
