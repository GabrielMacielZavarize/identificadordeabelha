# Copie para frontend/.env.local e preencha os valores.
# As variáveis VITE_* são expostas ao browser — nunca coloque segredos aqui.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── API Backend ──────────────────────────────────────────────────────────────
# Deixe vazio para usar o proxy local (vite.config.ts → /api → localhost:8000)
# Em produção (Vercel), aponte para o backend no Hugging Face:
# VITE_API_BASE_URL=https://seu-usuario-beeai-backend.hf.space/api/v1
VITE_API_BASE_URL=
