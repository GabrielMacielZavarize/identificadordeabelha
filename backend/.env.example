# Copie para backend/.env e ajuste os valores.
# Usado quando o backend roda fora do Docker (ambiente local direto).

# ─── Geral ────────────────────────────────────────────────────────────────────
BEEAI_PROJECT_NAME=BeeAI
BEEAI_DEBUG=false

# ─── Banco de dados ────────────────────────────────────────────────────────────
# SQLite local (desenvolvimento sem Docker):
BEEAI_DATABASE_URL=sqlite:////caminho/absoluto/para/data/db/app.sqlite3

# PostgreSQL via Supabase (staging / produção):
# BEEAI_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Storage local ─────────────────────────────────────────────────────────────
BEEAI_UPLOAD_DIR=/caminho/absoluto/para/data/uploads
BEEAI_ARTIFACTS_DIR=/caminho/absoluto/para/artifacts/models
BEEAI_MAX_UPLOAD_SIZE_MB=15

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Adicione a URL do frontend Vercel em produção:
BEEAI_CORS_ORIGINS=["http://localhost:5173","https://seu-projeto.vercel.app"]

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API
BEEAI_SUPABASE_URL=https://<project-ref>.supabase.co
BEEAI_SUPABASE_ANON_KEY=eyJ...
# JWT Secret — Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
BEEAI_SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# ─── Hugging Face ─────────────────────────────────────────────────────────────
# Token de leitura (necessário se o modelo for gated, ex: DINOv3)
# Encontre em: huggingface.co → Settings → Access Tokens
HF_TOKEN=hf_seu_token_read_aqui
BEEAI_HF_MODEL_REPO=seu-usuario/beeai-model
