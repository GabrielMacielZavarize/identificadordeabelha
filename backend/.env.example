# Copie este arquivo para backend/.env e ajuste os valores.
# Usado apenas quando o backend roda fora do Docker (ambiente local direto).

AUGOCHLOROPSIS_AI_PROJECT_NAME=Augochloropsis Classifier API
AUGOCHLOROPSIS_AI_DEBUG=false
AUGOCHLOROPSIS_AI_DATABASE_URL=sqlite:////caminho/absoluto/para/data/db/app.sqlite3
AUGOCHLOROPSIS_AI_UPLOAD_DIR=/caminho/absoluto/para/data/uploads
AUGOCHLOROPSIS_AI_ARTIFACTS_DIR=/caminho/absoluto/para/artifacts/models
AUGOCHLOROPSIS_AI_MAX_UPLOAD_SIZE_MB=15
AUGOCHLOROPSIS_AI_CORS_ORIGINS=["http://localhost:5173"]

# Opcional no backend local direto. Necessário se não usar `hf auth login`
# e o modelo ativo for gated no Hugging Face, como DINOv3.
HF_TOKEN=hf_seu_token_read_aqui
