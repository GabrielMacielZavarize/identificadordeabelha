# Copie este arquivo para backend/.env e ajuste os valores.
# Usado apenas quando o backend roda fora do Docker (ambiente local direto).

BEEAI_PROJECT_NAME=BeeAI
BEEAI_DEBUG=false
BEEAI_DATABASE_URL=sqlite:////caminho/absoluto/para/data/db/app.sqlite3
BEEAI_UPLOAD_DIR=/caminho/absoluto/para/data/uploads
BEEAI_ARTIFACTS_DIR=/caminho/absoluto/para/artifacts/models
BEEAI_MAX_UPLOAD_SIZE_MB=15
BEEAI_CORS_ORIGINS=["http://localhost:5173"]

# Opcional no backend local direto. Necessário se não usar `hf auth login`
# e o modelo ativo for gated no Hugging Face, como DINOv3.
HF_TOKEN=hf_seu_token_read_aqui

# --- OCI Object Storage (necessario para sincronizar datasets e artefatos) ---
# Namespace da conta OCI (encontrado em: OCI Console > Object Storage > Namespace)
BEEAI_OCI_NAMESPACE=seu_namespace_aqui
# Nome dos buckets (criar no OCI Console antes de usar)
BEEAI_OCI_BUCKET_DATASETS=beeai-datasets
BEEAI_OCI_BUCKET_ARTIFACTS=beeai-artifacts
# Regiao OCI (lista: https://docs.oracle.com/en-us/iaas/Content/General/Concepts/regions.htm)
BEEAI_OCI_REGION=sa-saopaulo-1
# Perfil do ~/.oci/config (padrao: DEFAULT)
BEEAI_OCI_CONFIG_PROFILE=DEFAULT
# Defina como true apenas quando rodar dentro de uma VM OCI (usa Instance Principal)
BEEAI_OCI_USE_INSTANCE_PRINCIPAL=false
